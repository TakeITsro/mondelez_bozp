{% extends 'bozp/site/contractor/_layout.twig' %}

{% set errors = errors ?? {} %}

{% block title %}{{ 'Prístup k permitu'|t('bozp') }}{% endblock %}

{% block content %}
    <section class="bozp-page bozp-page--contractor-auth">
        <div class="bozp-login">
            <header class="bozp-login__header">
                <h1>{{ 'Prístup k permitu'|t('bozp') }}</h1>
                <p class="bozp-login__lede">
                    {{
                        'Zadajte heslo, ktoré ste dostali e-mailom, pre zobrazenie permitu {n}.'|t('bozp', {
                            n: permit.permitNumber
                        })
                    }}
                </p>
            </header>

            <form method="post"
                  action="{{ url('bozp/c/' ~ token ~ '/auth') }}"
                  class="bozp-form bozp-form--contractor-auth"
                  novalidate>
                {{ csrfInput() }}

                <div class="bozp-form__field{% if errors.password is defined %} bozp-form__field--error{% endif %}">
                    <label for="password">
                        {{ 'Heslo'|t('bozp') }}
                        <span class="bozp-form__req">*</span>
                    </label>
                    <input type="password"
                           id="password"
                           name="password"
                           autocomplete="one-time-code"
                           required
                           autofocus
                           {% if errors.password is defined %}aria-invalid="true" aria-describedby="err-password"{% endif %}>
                    {% if errors.password is defined %}
                        <p class="bozp-form__error" id="err-password">{{ errors.password }}</p>
                    {% endif %}
                </div>

                <div class="bozp-form__actions">
                    <button type="submit" class="bozp-btn bozp-btn--primary">
                        {{ 'Pokračovať'|t('bozp') }}
                    </button>
                </div>
            </form>
        </div>
    </section>
{% endblock %}
