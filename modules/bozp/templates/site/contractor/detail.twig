{% extends 'bozp/site/contractor/_layout.twig' %}

{# Read-only contractor view of the permit + an upload form for
   supplementary documents (risk assessments, photos, evidence). #}

{% set controlLabels = {
    'used': 'V používaní'|t('bozp'),
    'not_used': 'Nepoužíva sa'|t('bozp'),
    'other': 'Iné'|t('bozp'),
} %}

{% macro yn(value) %}
    {% if value is null %}
        —
    {% elseif value %}{{ 'Áno'|t('bozp') }}{% else %}{{ 'Nie'|t('bozp') }}{% endif %}
{% endmacro %}

{% block title %}{{ 'Permit {n}'|t('bozp', {n: permit.permitNumber}) }}{% endblock %}

{% block content %}
    <section class="bozp-page bozp-page--contractor-detail">

        <header class="bozp-detail__header">
            <h1>{{ 'Permit {n}'|t('bozp', {n: permit.permitNumber}) }}</h1>
            <p class="bozp-detail__status">
                <strong>{{ 'Stav'|t('bozp') }}:</strong> {{ permit.status }}
            </p>
        </header>

        <dl class="bozp-detail__meta">
            <dt>{{ 'Dodávateľ'|t('bozp') }}</dt>
            <dd>
                {{ permit.contractorCompany ?: '—' }}
                {% if permit.contractorPersonName %}({{ permit.contractorPersonName }}){% endif %}
            </dd>

            <dt>{{ 'Miesto výkonu'|t('bozp') }}</dt>
            <dd>{{ permit.workLocation ?: '—' }}</dd>

            <dt>{{ 'Platnosť od'|t('bozp') }}</dt>
            <dd>{{ permit.validFrom ? permit.validFrom|date('d.m.Y') : '—' }}</dd>

            <dt>{{ 'Platnosť do'|t('bozp') }}</dt>
            <dd>{{ permit.validTo ? permit.validTo|date('d.m.Y H:i') : '—' }}</dd>
        </dl>

        {% if permit.workOverview %}
            <section class="bozp-detail__section">
                <h2>{{ 'Popis prác'|t('bozp') }}</h2>
                <p>{{ permit.workOverview|nl2br }}</p>
            </section>
        {% endif %}

        {% if zones is not empty %}
            <section class="bozp-detail__section">
                <h2>{{ 'Zóny'|t('bozp') }}</h2>
                <ul>
                    {% for z in zones %}
                        <li>{{ z.name }}</li>
                    {% endfor %}
                </ul>
            </section>
        {% endif %}

        <section class="bozp-detail__section">
            <h2>{{ 'Príprava pracoviska'|t('bozp') }}</h2>
            <dl>
                <dt>{{ 'Sú pracovné podmienky vhodné na vykonávanie prác?'|t('bozp') }}</dt>
                <dd>{{ _self.yn(permit.conditionsSuitable) }}</dd>
                <dt>{{ 'Je náradie a vybavenie v dobrom technickom stave?'|t('bozp') }}</dt>
                <dd>{{ _self.yn(permit.toolsInGoodCondition) }}</dd>
                <dt>{{ 'Existujú podmienky, pri ktorých je nutné práce zastaviť?'|t('bozp') }}</dt>
                <dd>{{ _self.yn(permit.hasStopConditions) }}</dd>
                {% if permit.stopConditionsDescription %}
                    <dt>{{ 'Popis podmienok pre zastavenie prác'|t('bozp') }}</dt>
                    <dd>{{ permit.stopConditionsDescription|nl2br }}</dd>
                {% endif %}
                <dt>{{ 'Je zavedený LOTO (uzamknutie / označenie)?'|t('bozp') }}</dt>
                <dd>{{ _self.yn(permit.lotoImplemented) }}</dd>
                {% if permit.emergencyPlan %}
                    <dt>{{ 'Núdzový plán / postup v prípade mimoriadnej udalosti'|t('bozp') }}</dt>
                    <dd>{{ permit.emergencyPlan|nl2br }}</dd>
                {% endif %}
            </dl>
        </section>

        <section class="bozp-detail__section">
            <h2>{{ 'Riziká a OOPP'|t('bozp') }}</h2>
            <table class="bozp-hazards">
                <thead>
                    <tr>
                        <th>{{ 'Kategória'|t('bozp') }}</th>
                        <th>{{ 'Vystavený'|t('bozp') }}</th>
                        <th>{{ 'Opatrenie / OOPP'|t('bozp') }}</th>
                        <th>{{ 'Kontrola počas činnosti'|t('bozp') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cat in hazardCategories %}
                        {% set h = hazards[cat.value] ?? null %}
                        <tr>
                            <th scope="row">{{ cat.label()|t('bozp') }}</th>
                            <td>{{ h ? _self.yn(h.exposed) : '—' }}</td>
                            <td>{{ h and h.measure ? h.measure|nl2br : '—' }}</td>
                            <td>
                                {% if h and h.controlDuringActivity %}
                                    {{ controlLabels[h.controlDuringActivity] ?? h.controlDuringActivity }}
                                    {% if h.controlDuringActivity == 'other' and h.controlDuringActivityOther %}
                                        — {{ h.controlDuringActivityOther }}
                                    {% endif %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </section>

        {# ---------- Closure status labels (reused below) ----------------- #}
        {% set completionLabels = {
            'work_completed': 'Práce boli dokončené'|t('bozp'),
            'equipment_operational': 'Zariadenie je prevádzkyschopné'|t('bozp'),
            'equipment_not_operational': 'Zariadenie nie je prevádzkyschopné'|t('bozp'),
            'personnel_and_materials_removed': 'Všetky osoby opustili oblasť a materiály a zariadenia boli z oblasti odstránené'|t('bozp'),
        } %}
        {% set closureLabels = completionLabels|merge({
            'work_suspended': 'Práce boli pozastavené'|t('bozp'),
        }) %}

        {# ---------- Contractor signature (single step): Done or Cancel -- #}
        <section class="bozp-detail__section bozp-detail__section--closure">
            <h2>{{ 'Dokončenie permitu'|t('bozp') }}</h2>

            {% if recipientClosureSignature %}
                {% set sigAsset = craft.assets().id(recipientClosureSignature.signatureAssetId).one() %}
                <div class="bozp-signature bozp-signature--signed">
                    {% set flags = permit.recipientClosureStatus ?? [] %}
                    {% if flags is iterable and flags|length > 0 %}
                        <ul class="bozp-closure__flags">
                            {% for f in flags %}
                                <li>✓ {{ closureLabels[f] ?? f }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                    {% if sigAsset %}
                        <img src="{{ sigAsset.url }}" alt="{{ 'Podpis'|t('bozp') }}"
                             class="bozp-signature__image"
                             style="max-width:360px;max-height:140px;border:1px solid #ddd;background:#fff;">
                    {% endif %}
                    <dl class="bozp-signature__meta">
                        <dt>{{ 'Podpísal'|t('bozp') }}</dt>
                        <dd>{{ recipientClosureSignature.signerName }}</dd>
                        <dt>{{ 'Dátum podpisu'|t('bozp') }}</dt>
                        <dd>{{ recipientClosureSignature.signatureDate ? recipientClosureSignature.signatureDate|date('d.m.Y') : '—' }}</dd>
                        <dt>{{ 'Zaznamenané'|t('bozp') }}</dt>
                        <dd>{{ recipientClosureSignature.signedAt|date('d.m.Y H:i') }}</dd>
                    </dl>
                </div>
            {% elseif canClose or canCancel %}
                {% set ce = closeErrors ?? {} %}
                {% set cv = closeValues ?? {} %}
                {% set checked = cv.closureStatus ?? [] %}
                {% set xe = cancelErrors ?? {} %}
                {% set xv = cancelValues ?? {} %}

                <p class="bozp-empty">
                    {{ 'Vyberte jednu z možností: dokončenie alebo zrušenie prác.'|t('bozp') }}
                </p>

                <div class="bozp-recipient-actions" style="display:flex;gap:12px;flex-wrap:wrap;margin-top:8px;">
                    {% if canClose %}
                        <button type="button" class="bozp-btn bozp-btn--primary"
                                data-bozp-dialog-open="bozp-dialog-close">
                            {{ 'Práce dokončené'|t('bozp') }}
                        </button>
                    {% endif %}
                    {% if canCancel %}
                        <button type="button" class="bozp-btn bozp-btn--secondary"
                                data-bozp-dialog-open="bozp-dialog-cancel"
                                style="background:#cf2929;color:#fff;border-color:#cf2929;">
                            {{ 'Práce zrušené'|t('bozp') }}
                        </button>
                    {% endif %}
                </div>

                {# Modal A: Work done — completion checkboxes #}
                {% if canClose %}
                    {% set completionExtra %}
                        <div class="bozp-form__field{% if ce.closureStatus is defined %} bozp-form__field--error{% endif %}">
                            <label>{{ 'Stav po dokončení'|t('bozp') }} <span class="bozp-form__req">*</span></label>
                            {% for key, label in completionLabels %}
                                <label class="bozp-form__check" style="display:flex;gap:8px;align-items:center;margin:6px 0;">
                                    <input type="checkbox" name="closureStatus[]" value="{{ key }}"
                                           {% if key in checked %}checked{% endif %}>
                                    <span>{{ label }}</span>
                                </label>
                            {% endfor %}
                            {% if ce.closureStatus is defined %}
                                <p class="bozp-form__error">{{ ce.closureStatus }}</p>
                            {% endif %}
                        </div>
                    {% endset %}

                    {% include 'bozp/site/_sign-dialog.twig' with {
                        id: 'bozp-dialog-close',
                        action: url('bozp/c/' ~ token ~ '/close'),
                        openOnLoad: ce|length > 0,
                        title: 'Práce dokončené'|t('bozp'),
                        intro: 'Potvrdzujete, že práce na tomto permite boli ukončené. Označte aktuálny stav pracoviska.'|t('bozp'),
                        warning: 'Po podpise dokončenia sa už údaje nedajú meniť.'|t('bozp'),
                        submitLabel: 'Podpísať a potvrdiť'|t('bozp'),
                        showEmployer: false,
                        errors: ce,
                        values: cv,
                        extraFields: completionExtra,
                    } only %}
                {% endif %}

                {# Modal B: Work cancelled — reason textarea #}
                {% if canCancel %}
                    {% set cancelExtra %}
                        <div class="bozp-form__field{% if xe.reason is defined %} bozp-form__field--error{% endif %}">
                            <label>{{ 'Dôvod zrušenia'|t('bozp') }}</label>
                            <textarea name="reason" rows="3"
                                      placeholder="{{ 'Krátko popíšte, prečo nie je možné práce vykonať.'|t('bozp') }}">{{ xv.reason ?? '' }}</textarea>
                            {% if xe.reason is defined %}
                                <p class="bozp-form__error">{{ xe.reason }}</p>
                            {% endif %}
                        </div>
                    {% endset %}

                    {% include 'bozp/site/_sign-dialog.twig' with {
                        id: 'bozp-dialog-cancel',
                        action: url('bozp/c/' ~ token ~ '/cancel'),
                        openOnLoad: xe|length > 0,
                        title: 'Zrušenie prác'|t('bozp'),
                        intro: 'Potvrdzujete, že práce nemôžu byť vykonané za týchto podmienok a permit má byť zrušený.'|t('bozp'),
                        warning: 'Po podpise zrušenia sa permit uzamkne ako zrušený a nedá sa znova otvoriť.'|t('bozp'),
                        submitLabel: 'Zrušiť a podpísať'|t('bozp'),
                        showEmployer: false,
                        errors: xe,
                        values: xv,
                        extraFields: cancelExtra,
                    } only %}
                {% endif %}
            {% else %}
                <p class="bozp-empty">
                    {{ 'Dokončenie zatiaľ nie je možné.'|t('bozp') }}
                </p>
            {% endif %}
        </section>

        {# ---------- Shared signature_pad runtime (binds all dialogs) ---- #}
        {% if canClose or canCancel %}
            <script src="https://cdn.jsdelivr.net/npm/signature_pad@4/dist/signature_pad.umd.min.js"></script>
            <script>
                (function () {
                    document.querySelectorAll('[data-bozp-dialog-open]').forEach(function (btn) {
                        btn.addEventListener('click', function () {
                            var d = document.getElementById(btn.getAttribute('data-bozp-dialog-open'));
                            if (d) bozpOpenDialog(d, 'warning');
                        });
                    });

                    document.querySelectorAll('.bozp-sign-dialog').forEach(function (dialog) {
                        var stages = dialog.querySelectorAll('.bozp-dialog__stage');
                        var canvas = dialog.querySelector('canvas[data-bozp-sigpad]');
                        var hidden = dialog.querySelector('input[name="signatureData"]');
                        var clearBtn = dialog.querySelector('[data-bozp-sigpad-clear]');
                        var cancelBtn = dialog.querySelector('[data-bozp-action="cancel"]');
                        var proceedBtn = dialog.querySelector('[data-bozp-action="proceed"]');
                        var backBtn = dialog.querySelector('[data-bozp-action="back"]');
                        var pad = null;

                        function showStage(name) {
                            stages.forEach(function (s) {
                                s.hidden = (s.getAttribute('data-stage') !== name);
                            });
                            if (name === 'form') {
                                window.requestAnimationFrame(initPad);
                            }
                        }

                        function initPad() {
                            if (!window.SignaturePad || !canvas) { return; }
                            if (!pad) {
                                pad = new SignaturePad(canvas, {
                                    backgroundColor: 'rgba(255,255,255,1)',
                                    penColor: '#000',
                                });
                            }
                            var ratio = Math.max(window.devicePixelRatio || 1, 1);
                            canvas.width = canvas.offsetWidth * ratio;
                            canvas.height = canvas.offsetHeight * ratio;
                            canvas.getContext('2d').scale(ratio, ratio);
                            pad.clear();
                        }

                        if (cancelBtn) cancelBtn.addEventListener('click', function () { dialog.close(); });
                        if (proceedBtn) proceedBtn.addEventListener('click', function () { showStage('form'); });
                        if (backBtn) backBtn.addEventListener('click', function () { showStage('warning'); });
                        if (clearBtn) clearBtn.addEventListener('click', function () { if (pad) pad.clear(); });

                        dialog.bozpShowStage = showStage;

                        var form = dialog.querySelector('form');
                        if (form) {
                            form.addEventListener('submit', function () {
                                if (hidden) hidden.value = (pad && !pad.isEmpty()) ? pad.toDataURL('image/png') : '';
                            });
                        }

                        var openOnLoad = dialog.getAttribute('data-open-on-load');
                        if (openOnLoad) bozpOpenDialog(dialog, openOnLoad);
                    });

                    function bozpOpenDialog(dialog, initialStage) {
                        if (dialog.bozpShowStage) dialog.bozpShowStage(initialStage || 'warning');
                        if (typeof dialog.showModal === 'function') dialog.showModal();
                        else dialog.setAttribute('open', '');
                    }
                    window.bozpOpenDialog = bozpOpenDialog;
                })();
            </script>
        {% endif %}

        {# ---------- Attachments: list + upload --------------------------- #}
        <section class="bozp-detail__section bozp-detail__section--uploads">
            <h2>{{ 'Prílohy dodávateľa'|t('bozp') }}</h2>

            {% if attachments is not empty %}
                <ul class="bozp-attachments">
                    {% for a in attachments %}
                        {% set asset = craft.assets().id(a.assetId).one() %}
                        <li>
                            {% if asset %}
                                <a href="{{ asset.url }}" target="_blank" rel="noopener">{{ asset.filename }}</a>
                                <span class="bozp-attachments__meta">
                                    · {{ a.dateCreated|date('d.m.Y H:i') }}
                                </span>
                            {% else %}
                                <span class="bozp-attachments__missing">{{ 'Súbor nie je dostupný'|t('bozp') }}</span>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="bozp-attachments__empty">{{ 'Zatiaľ neboli nahrané žiadne prílohy.'|t('bozp') }}</p>
            {% endif %}

            <form method="post"
                  action="{{ url('bozp/c/' ~ token ~ '/upload') }}"
                  enctype="multipart/form-data"
                  class="bozp-form bozp-form--upload"
                  novalidate>
                {{ csrfInput() }}

                <div class="bozp-form__field">
                    <label for="attachment">{{ 'Nahrať súbor (PDF, DOCX, JPG, PNG, max 10 MB)'|t('bozp') }}</label>
                    <input type="file"
                           id="attachment"
                           name="attachment"
                           accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png"
                           required>
                </div>

                <div class="bozp-form__actions">
                    <button type="submit" class="bozp-btn bozp-btn--primary">
                        {{ 'Nahrať'|t('bozp') }}
                    </button>
                </div>
            </form>
        </section>

    </section>
{% endblock %}
